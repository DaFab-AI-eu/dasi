DASI_VERSION=0.2.9
# --- MinIO Credentials (for local dev stack) ---
# Change these if shared beyond local development.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioPassword123
# Client endpoint used by boto3. If you run the client outside Compose,
# point this at a host-reachable address such as https://localhost:9000.
MINIO_HOST=https://minio:9000
# Self-signed dev cert: skip TLS verification in boto3/clients.
MINIO_VERIFY_TLS=false
MINIO_HOSTNAME=minio
MINIO_PORT=9000
MINIO_BUCKET=dasi-dev
MINIO_REGION=eu-west-1

# --- Rucio Server Configuration ---
# Database backend
POSTGRES_DB=rucio_db
POSTGRES_USER=rucio_user
POSTGRES_PASSWORD=ruciosecret123
RUCIO_CFG_DATABASE_DEFAULT=postgresql+psycopg://rucio_user:ruciosecret123@rucio-db:5432/rucio_db

# Authentication
RUCIO_ACCOUNT=root
RUCIO_AUTH_TYPE=userpass
RUCIO_USERNAME=ddmlab
RUCIO_PASSWORD=secret

# Server configuration
RUCIO_HOST=http://rucio-server:80
RUCIO_HOSTNAME=localhost
RUCIO_ENABLE_SSL=False
RUCIO_SERVER_TYPE=api
RUCIO_LOG_LEVEL=info
